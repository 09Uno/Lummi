# =============================================================================
# Copie este arquivo para .env e preencha com os valores reais.
# Nunca commite .env — está no .gitignore.
# =============================================================================

# ---- Supabase (cliente — seguro no bundle) ----
# Chave "publishable" (sb_publishable_*), NÃO a service role.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxx"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# ---- Supabase (servidor — NUNCA prefixar com VITE_) ----
# Mesmos valores acima, mas lidos pelo Node em runtime (SSR / server fns).
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxx"
SUPABASE_PROJECT_ID="<project-ref>"

# Service role — bypassa RLS. Usada APENAS em src/integrations/supabase/client.server.ts.
# Se vazar, um atacante lê/apaga qualquer linha de qualquer usuário. Trate como senha root.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxxxx"

# ---- Gemini (IA) ----
# Aceita qualquer uma das três (fallback nessa ordem). Só GEMINI_API_KEY basta.
GEMINI_API_KEY="AIzaSy..."
# GOOGLE_GENERATIVE_AI_API_KEY=""
# GOOGLE_API_KEY=""
# Opcional: sobrescreve o modelo padrão (gemini-3.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"

# ---- HubSpot (Private App Token, server-only) ----
# Gere em: HubSpot → Settings → Integrations → Private Apps.
# Escopos mínimos: crm.objects.companies.read, crm.objects.companies.write.
HUBSPOT_ACCESS_TOKEN="pat-na1-xxxxxxxxxxxxxxxxxxxxxx"

# ---- Cache de busca de leads ----
# TTL em dias do cache de resultados de prospecção (default: 1).
CACHE_TTL_DAYS="1"

# ---- Runtime (usado no container) ----
NODE_ENV="production"
HOST="0.0.0.0"
PORT="3000"
TZ="America/Bahia"
