# =============================================================================
# Copie este arquivo para .env e preencha os SECRETS abaixo.
# Nunca commite .env — está no .gitignore.
#
# Os valores de Supabase (URL / PROJECT_ID / PUBLISHABLE_KEY) são inerentemente
# públicos (viajam pro browser em cada sessão), por isso ficam pré-preenchidos
# aqui. Só troque se mudar de projeto Supabase.
# =============================================================================

# ---- Supabase (cliente — seguro no bundle) ----
VITE_SUPABASE_URL="https://tcanetqunqyqqnqhemnv.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_5o1BzRkJZsGGXsvpmbphvg_kpPNJQFt"
VITE_SUPABASE_PROJECT_ID="tcanetqunqyqqnqhemnv"

# ---- Supabase (servidor — NUNCA prefixar com VITE_) ----
# Mesmos valores acima, mas lidos pelo Node em runtime (SSR / server fns).
SUPABASE_URL="https://tcanetqunqyqqnqhemnv.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_5o1BzRkJZsGGXsvpmbphvg_kpPNJQFt"
SUPABASE_PROJECT_ID="tcanetqunqyqqnqhemnv"

# Service role — bypassa RLS. Usada APENAS em src/integrations/supabase/client.server.ts.
# Se vazar, um atacante lê/apaga qualquer linha de qualquer usuário. Trate como senha root.
# Dashboard → Project Settings → API Keys → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY="sb_secret_PREENCHER"

# ---- Anthropic Claude (IA) ----
# Gere em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-api03-PREENCHER"
# CLAUDE_API_KEY=""   # fallback alternativo
# Opcional: sobrescreve o modelo padrão (claude-sonnet-4-6).
# CLAUDE_MODEL="claude-sonnet-4-6"

# ---- HubSpot (Private App Token, server-only) ----
# Gere em: HubSpot → Settings → Integrations → Private Apps.
# Escopos mínimos: crm.objects.companies.read, crm.objects.companies.write.
HUBSPOT_ACCESS_TOKEN="pat-na1-PREENCHER"

# ---- Cache de busca de leads ----
# TTL em dias do cache de resultados de prospecção (default: 1).
CACHE_TTL_DAYS="1"

# ---- Runtime (usado no container) ----
NODE_ENV="production"
HOST="0.0.0.0"
PORT="3000"
TZ="America/Bahia"
